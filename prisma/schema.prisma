generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String?
  name          String?
  createdAt     DateTime  @default(now())
  profile       Profile?
  applications  Application[]
  resumes       Resume[]
  preferences   JobPreference?
  credentials   PlatformCredential[]
  auditLogs     AuditLog[]
}

model Profile {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills         String[]
  education      Json
  experience     Json
  certifications Json
  projects       Json
  profileVector  Unsupported("vector(1536)")?
}

model JobListing {
  id                String   @id @default(cuid())
  platform          String
  externalId        String?
  title             String
  company           String
  location          String?
  description       String   @db.Text
  descriptionVector Unsupported("vector(1536)")?
  salaryMin         Int?
  salaryMax         Int?
  listingUrl        String   @unique
  atsType           String?
  matchScore        Float?
  status            String   @default("NEW")
  discoveredAt      DateTime @default(now())
  applications      Application[]
  coverLetters      CoverLetter[]
}

model Application {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobListingId       String
  jobListing         JobListing @relation(fields: [jobListingId], references: [id], onDelete: Cascade)
  resumeVersionId    String?
  coverLetterId      String?
  status             String   @default("QUEUED")
  screenshotUrl      String?
  referenceId        String?
  errorMessage       String?  @db.Text
  submittedAt        DateTime?
}

model Resume {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  version         String
  originalContent String   @db.Text
  tailoredContent String?  @db.Text
  tailoredForJobId String?
  pdfUrl          String?
  keywordDensity  Float?
  isActive        Boolean  @default(true)
}

model CoverLetter {
  id              String   @id @default(cuid())
  userId          String
  jobListingId    String
  jobListing      JobListing @relation(fields: [jobListingId], references: [id], onDelete: Cascade)
  content         String   @db.Text
  wordCount       Int?
}

model JobPreference {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetRoles      String[]
  locations        String[]
  remote           Boolean  @default(true)
  salaryMin        Int?
  dailyLimit       Int      @default(10)
  blacklistedComps String[]
}

model PlatformCredential {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform        String
  vaultPath       String
  isActive        Boolean  @default(true)
  lastUsed        DateTime?
  warnings        Int      @default(0)
}

model AuditLog {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action          String
  resource        String
  ipHash          String
  timestamp       DateTime @default(now())
  metadata        Json?
}

model HumanReviewItem {
  id              String   @id @default(cuid())
  userId          String
  applicationId   String
  type            String
  screenshotUrl   String?
  status          String   @default("PENDING")
  resolvedAt      DateTime?
}
